ENV=development
DEBUG=false
SECRET_KEY=change-me
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
DATABASE_SSLMODE=require
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=
ADMIN_API_KEY=
AI_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
RETRIEVAL_PROVIDER=mock
EXTERNAL_RETRIEVAL_ENABLED=false
OPS_NOTIFICATIONS_ENABLED=false
OPS_WEBHOOK_URL=
OPS_WEBHOOK_SECRET=
OPS_NOTIFICATION_MIN_SEVERITY=warning
OPS_NOTIFICATION_TIMEOUT_SECONDS=5
ARTICLE_FETCH_TIMEOUT_SECONDS=15
ARTICLE_MAX_CHARS=12000
ANALYZE_QUOTA_ENABLED=true
ANALYZE_DAILY_LIMIT=10
ANALYZE_QUOTA_WINDOW_SECONDS=86400
ANALYZE_COOLDOWN_SECONDS=10
